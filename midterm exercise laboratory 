<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Company Profile Card</title>
    
    <link rel="stylesheet" href="styles.css">

    <style>
        article {
            background-color: white;
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
            max-width: 400px;
        }
    </style>
</head>
<body>

    <header>
        <h1>EcoTrack Solutions</h1>
        <p>Leading the way in sustainable tech.</p>
    </header>

    <main>
        <article>
            <h2>About Us</h2>
            <p>We provide innovative inventory management systems to help businesses track their environmental impact and operational efficiency.</p>
        </article>
    </main>

    <footer>
        <p>&copy; 2026 EcoTrack Solutions</p>
        
        <button style="background-color: #007bff; color: white; padding: 10px 20px; border: none; cursor: pointer;">
            Contact Us
        </button>
    </footer>

</body>
</html>
